# --- Backend (NestJS) ---

# Port the NestJS server listens on.
PORT=3001

# CORS allowlist. Comma-separated origins. In dev, this should include the
# Next.js dev server origin. In docker-compose, the Route Handler talks to
# the backend over the internal network so CORS is irrelevant; we only need
# it when the browser talks directly to NestJS (i.e. during Part B, before
# the BFF proxy).
CORS_ORIGIN=http://localhost:3000

# LLM provider switch.
#   - "mock"  : deterministic, network-free provider used in tests + when no
#               LLM_API_KEY is set. Useful for quick local demos.
#   - "gemini": real Google Gemini streaming via REST.
# If LLM_PROVIDER is unset and LLM_API_KEY is empty, the backend auto-falls
# back to mock and logs a warning.
LLM_PROVIDER=mock

# Google Gemini credentials. Only required when LLM_PROVIDER=gemini.
LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash

# --- Frontend (Next.js) ---

# Where the Server Component and the BFF Route Handler reach NestJS.
# In docker-compose this resolves to the service name; locally it's http://localhost:3001.
NEST_API_URL=http://localhost:3001

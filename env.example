# --- Backend (NestJS) ---

# Port the NestJS server listens on.
PORT=3001

# CORS allowlist. Comma-separated origins. In dev this should include the
# Next.js dev server. In docker-compose the Route Handler talks to NestJS
# over the internal network, so CORS only matters for direct browser calls.
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
# Two sliding windows per session, enforced at BOTH the BFF (early-reject)
# and the NestJS backend (authoritative gate):
#   - 20 requests / hour  (sustained)
#   - 5  requests / minute (burst)
# The closer reset wins on a deny, so Retry-After is as small as possible.
# These limits are defined as exported constants — no env var by design:
#   backend/src/chat/rate-limit.service.ts   (RATE_LIMIT_CONFIG)
#   frontend/lib/rate-limit.ts               (RATE_LIMIT_CONFIG)
# Keep the two files in sync if you tune them.

# ---------------------------------------------------------------------------
# LLM provider selection
# ---------------------------------------------------------------------------
# The backend ships with four provider implementations and selects one at
# boot based on LLM_PROVIDER. They all expose the same internal interface;
# swapping one for another is a config-only change (no code edits).
#
#   1) "mock"        Deterministic, network-free. Used in tests and as a
#                    fallback when LLM_API_KEY is unset. Good for offline demos.
#
#   2) "gemini"      Google AI Studio (works with both gemini-* and gemma-*
#                    models served by the v1beta endpoint).
#
#   3) "anthropic"   Claude models via api.anthropic.com (Messages API,
#                    x-api-key auth, distinct wire format with content blocks).
#                    Aliases: anthropic | claude.
#
#   4) Any "OpenAI Chat Completions"-compatible vendor:
#                    openai | groq | cerebras | together | openrouter |
#                    mistral | ollama | openai-compatible
#                    All of these speak the same wire format. The vendor alias
#                    alone is enough — the backend knows each vendor's default
#                    endpoint. LLM_BASE_URL is only needed when you want to
#                    override (e.g. self-hosted LiteLLM/vLLM gateway, or
#                    routing Azure/Bedrock/Vertex via a normalizing proxy).
#
# Auto-detect when LLM_PROVIDER is not set:
#   - LLM_MODEL starts with "claude-"            → Anthropic
#   - LLM_BASE_URL contains api.anthropic.com    → Anthropic
#   - LLM_BASE_URL contains googleapis.com       → Gemini
#   - otherwise                                  → OpenAI-compatible
#
# Health probe: the backend pings the configured model on /chat/health/llm
# with a tiny text + tool prompt and surfaces problems (auth, quota, tools
# unsupported, <think> leakage) as a persistent banner in the UI. Check it
# whenever you swap models — it will tell you exactly what won't work.
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# ---------------------------------------------------------------------------
# Verified vendor recipes — uncomment ONE block to switch.
# ---------------------------------------------------------------------------
# Groq (recommended for free-tier demos: 14.4k req/day, ~300 tok/s)
#   LLM_PROVIDER=groq
#   LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_MODEL=llama-3.3-70b-versatile
#
# OpenAI (requires paid account or new-account credit)
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_MODEL=gpt-4o-mini
#
# Cerebras (free tier, Llama-family on dedicated inference chips)
#   LLM_PROVIDER=cerebras
#   LLM_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_MODEL=llama3.3-70b
#
# OpenRouter (proxy to ~100 models, free models available)
#   LLM_PROVIDER=openrouter
#   LLM_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct
#
# Ollama (local, fully offline once the model is pulled)
#   LLM_PROVIDER=ollama
#   LLM_API_KEY=ollama          # any non-empty string; ollama ignores auth
#   LLM_MODEL=llama3.1:8b
#
# Self-hosted OpenAI-compatible gateway (LiteLLM, vLLM, etc.)
#   LLM_PROVIDER=openai-compatible
#   LLM_API_KEY=whatever-your-gateway-expects
#   LLM_MODEL=your-deployed-model
#   LLM_BASE_URL=http://your-gateway:4000/v1     # required for custom hosts
#
# Google AI Studio — Gemini family (fast, tight free-tier quota)
#   LLM_PROVIDER=gemini
#   LLM_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_MODEL=gemini-2.5-flash
#   # LLM_BASE_URL not required; defaults to the v1beta endpoint.
#
# Google AI Studio — Gemma family (slower, 1.5k req/day free tier)
#   LLM_PROVIDER=gemini
#   LLM_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_MODEL=gemma-4-26b-a4b-it
#
# Anthropic (Claude — requires prepaid credits)
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_MODEL=claude-3-5-haiku-20241022
#   # LLM_BASE_URL not required; defaults to https://api.anthropic.com/v1
#
# ---------------------------------------------------------------------------
# Vendors NOT supported natively — route via a normalizing gateway instead.
# ---------------------------------------------------------------------------
#
# Azure OpenAI, AWS Bedrock, Google Vertex AI, Cohere native, and any
# other non-OpenAI/Anthropic/Gemini wire format won't work directly. The
# canonical workaround is to put OpenRouter (cloud) or LiteLLM (self-hosted)
# in front and point LLM_BASE_URL at it. Both expose the OpenAI shape over
# 100+ underlying providers, so the OpenAI-compatible adapter in this
# backend can talk to anything they support.
#
# Example: Anthropic Claude via OpenRouter (no x-api-key, no custom format):
#   LLM_PROVIDER=openrouter
#   LLM_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_MODEL=anthropic/claude-3.5-sonnet
#
# Example: any model via a local LiteLLM gateway:
#   LLM_PROVIDER=openai-compatible
#   LLM_API_KEY=anything-your-gateway-expects
#   LLM_MODEL=azure/gpt-4o     # whatever name your gateway exposes
#   LLM_BASE_URL=http://litellm:4000/v1

# ---------------------------------------------------------------------------
# Expert domain (configurable persona)
# ---------------------------------------------------------------------------
# The assistant persona, off-topic refusal, UI copy, and advertised tool
# metadata are all driven by these env vars. Defaults below preserve the
# TypeScript-expert behavior, so leaving everything unset works out of the
# box. Override any of them to repurpose the assistant for a different
# domain (sports, cooking, physics, etc.) without code changes.
#
# Backend reads these via ExpertConfigService and exposes a snapshot at
# `GET /chat/config`; the Next.js Server Component fetches it once at SSR
# to render the page title, header H1/subtitle, and empty-state placeholder.
#
# Validation runs at boot (backend/src/config/env.validation.ts):
#   - empty strings are rejected
#   - EXPERT_TOOL_NAME must match /^[a-zA-Z0-9_-]{1,64}$/
#     (Gemini / OpenAI / Anthropic all enforce this on tool names)
#   - EXPERT_DOMAIN and EXPERT_DESCRIPTION are REQUIRED in production
#     (NODE_ENV=production) so a missing override fails fast at startup
#     instead of silently serving the default TypeScript persona.
#
# Worked override example — repurpose to a sports expert:
#   EXPERT_DOMAIN="sports"
#   EXPERT_DESCRIPTION="You are a sports expert assistant with deep
#     knowledge of major leagues, statistics, and history."
#   OFF_TOPIC_MESSAGE="I can only answer questions related to sports."
#   APP_TITLE="Sports Expert"
#   APP_SUBTITLE="online · ask anything about sports"
#   EXPERT_TOOL_NAME="lookup_sport_stats"
#   EXPERT_TOOL_DESCRIPTION="Look up athlete or team statistics."
#
# Leave any of the optional ones unset to keep the TypeScript default for
# that field. They're all independent.
# EXPERT_DOMAIN=
# EXPERT_DESCRIPTION=
# OFF_TOPIC_MESSAGE=
# APP_TITLE=
# APP_SUBTITLE=
# EXPERT_TOOL_NAME=
# EXPERT_TOOL_DESCRIPTION=

# --- Frontend (Next.js) ---

# Where the Server Component and the BFF Route Handler reach NestJS.
# In docker-compose this resolves to the service name; locally it's
# http://localhost:3001.
NEST_API_URL=http://localhost:3001
